// OfferAccept v2 — Prisma Schema
// Database: PostgreSQL
//
// Security model summary:
//   - Recipient tokens are never stored raw; only SHA-256 hashes are persisted.
//   - Final acceptance requires two factors: email link (token) + email OTP.
//   - Offer content is frozen into an immutable snapshot at send time.
//   - Signing events form a hash chain — each event commits to the previous.
//   - AcceptanceCertificate is derived from an immutable AcceptanceRecord,
//     not from mutable offer state.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ─────────────────────────────────────────────────────────────

// Role within an organization. Separate from UserRole (which includes
// INTERNAL_SUPPORT — a platform-level role, not an org-level role).
// Hierarchy for RBAC: OWNER > ADMIN > MEMBER > VIEWER
enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// Soft-delete cascade policy:
//   When deletedAt is set on an Organization the application layer is responsible
//   for propagating the soft-delete to all dependent records before or within the
//   same transaction. There are NO database-level cascades on deletedAt.
//   Dependent models affected: Offer, Membership, Invite, Subscription, File,
//   ApiKey, WebhookEndpoint. Until a formal deletion workflow is implemented,
//   the org deletion flow must set deletedAt on all related records explicitly.
model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users            User[]
  offers           Offer[]
  subscription     Subscription?
  memberships      Membership[]
  invites          Invite[]
  files            File[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]

  @@map("organizations")
}

// ─── Membership ───────────────────────────────────────────────────────────────
// Join table between users and organizations.
// One row per user-organization pair. Role is the user's role within that org.
// @@unique([userId, organizationId]) prevents duplicate memberships.

model Membership {
  id             String      @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole     @default(MEMBER)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("memberships")
}

// ─── Invite ───────────────────────────────────────────────────────────────────
// An invitation to join an organization.
// tokenHash: SHA-256 of the raw token delivered in the invite URL.
// Single-use: acceptedAt is set when consumed; revokedAt when cancelled.
// TTL: expiresAt enforced in application layer + background cleanup.

model Invite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  // SHA-256 hex of raw token — raw token is never stored
  tokenHash      String    @unique
  expiresAt      DateTime
  invitedById    String              // userId of the inviter
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
  @@map("invites")
}

// ─── File ─────────────────────────────────────────────────────────────────────
// Org-scoped file registry. Tracks files uploaded via presigned S3 URLs.
//
// Upload lifecycle:
//   1. POST /files/presign  → creates row with status=PENDING, returns presigned URL
//   2. Client PUTs file bytes directly to S3
//   3. POST /files/complete → validates SHA-256, sets status=READY
//
// sha256 is the client-provided hex digest, verified server-side after upload.
// s3Key format: {organizationId}/{fileId}/{filename}
// PENDING rows older than 1 hour may be cleaned up by a background job.

enum FileStatus {
  PENDING  // presigned URL issued; upload not yet confirmed
  READY    // upload confirmed and hash verified
  DELETED  // soft-deleted; row kept for audit history
}

model File {
  id               String     @id @default(cuid())
  organizationId   String
  uploadedByUserId String?    // userId; null for system-initiated uploads
  filename         String
  mime             String
  size             Int        // bytes
  sha256           String     // hex-encoded SHA-256 of file content; '' while PENDING
  s3Key            String     @unique
  status           FileStatus @default(PENDING)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("files")
}

// ─── User ─────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  // Internal OfferAccept staff role. Cross-org read access + limited safe actions.
  // Must never be assigned to customer users.
  INTERNAL_SUPPORT
}

model User {
  id             String    @id @default(cuid())
  // Legacy single-org FK — nullable since multi-org uses Membership as canonical source.
  // New code reads org context from Membership; this field is kept as a fallback
  // for backward compatibility until a full data migration removes it.
  organizationId String?
  email          String    @unique
  name           String
  role           UserRole  @default(MEMBER)
  hashedPassword String
  emailVerified  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization            Organization?            @relation(fields: [organizationId], references: [id])
  offersCreated           Offer[]                  @relation("CreatedByUser")
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  memberships             Membership[]

  @@index([organizationId])
  @@map("users")
}

// ─── Session ──────────────────────────────────────────────────────────────────
// One row per active refresh-token issuance.
// refreshTokenHash: SHA-256 of the raw random refresh token (never stored raw).
// revokedAt: set on logout or token rotation — row is kept for audit purposes.

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

// ─── EmailVerificationToken ───────────────────────────────────────────────────
// Single-use token sent by email to verify a user's address.
// tokenHash: SHA-256 of the raw token delivered in the verification URL.
// usedAt: set when the token is consumed — row is kept for audit purposes.

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("email_verification_tokens")
}

// ─── PasswordResetToken ───────────────────────────────────────────────────────
// Single-use token sent by email to reset a user's password.
// tokenHash: SHA-256 of the raw token delivered in the reset URL.
// usedAt: set when the token is consumed — row is kept for audit purposes.

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Offer ────────────────────────────────────────────────────────────────────
// Mutable operational record. Once sent, authoritative content lives in
// OfferSnapshot, not here. This record tracks lifecycle state only.

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

model Offer {
  id             String      @id @default(cuid())
  organizationId String
  createdById    String
  title          String
  message        String?     @db.Text
  status         OfferStatus @default(DRAFT)
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  organization Organization          @relation(fields: [organizationId], references: [id])
  createdBy    User                  @relation("CreatedByUser", fields: [createdById], references: [id])
  // v1: one recipient enforced by OfferRecipient.offerId @unique
  recipient    OfferRecipient?
  documents    OfferDocument[]
  // Frozen at send time — null while DRAFT
  snapshot          OfferSnapshot?
  certificate       AcceptanceCertificate?
  deliveryAttempts  OfferDeliveryAttempt[]

  reminderSchedule  ReminderSchedule?

  @@index([organizationId, status])
  @@index([createdById])
  // Used by the expiry background job: SELECT … WHERE status = 'SENT' AND expiresAt < NOW()
  @@index([status, expiresAt])
  @@map("offers")
}

// ─── OfferDocument ────────────────────────────────────────────────────────────
// Document metadata. The file lives in object storage at `storageKey`.
// sha256Hash is computed at upload time and is authoritative for integrity checks.
// Documents are append-only — no soft-delete; instead, remove from offer before sending.

model OfferDocument {
  id         String   @id @default(cuid())
  offerId    String
  filename   String
  storageKey String
  mimeType   String
  sizeBytes  Int
  // SHA-256 hex digest of file content, computed at upload time.
  // Copied into OfferSnapshotDocument to bind the snapshot to the exact file bytes.
  sha256Hash String
  createdAt  DateTime @default(now())

  offer             Offer                  @relation(fields: [offerId], references: [id])
  snapshotDocuments OfferSnapshotDocument[]

  @@index([offerId])
  @@map("offer_documents")
}

// ─── OfferSnapshot ────────────────────────────────────────────────────────────
// Immutable frozen copy of offer content created atomically when an offer is sent.
// This is what the recipient sees and what the certificate is derived from.
// IMPORTANT: never update this record after creation.
//
// contentHash = SHA-256 of the canonical JSON serialization of:
//   { title, message, senderName, senderEmail, expiresAt, documents: [{ filename, storageKey, sha256Hash }] }
// sorted keys, no whitespace. This allows independent re-verification.

model OfferSnapshot {
  id           String    @id @default(cuid())
  // 1:1 with Offer — enforced here and by Offer.snapshot relation
  offerId      String    @unique
  // Content frozen at send time
  title        String
  message      String?   @db.Text
  // Sender identity frozen at send time (user may later change name/email)
  senderName   String
  senderEmail  String
  expiresAt    DateTime?
  // SHA-256 of canonical content — see comment above
  contentHash  String
  // No updatedAt — this record is immutable after creation
  frozenAt     DateTime  @default(now())

  offer     Offer                  @relation(fields: [offerId], references: [id])
  documents OfferSnapshotDocument[]
  sessions  SigningSession[]
  records   AcceptanceRecord[]

  @@map("offer_snapshots")
}

// ─── OfferSnapshotDocument ────────────────────────────────────────────────────
// Frozen document references within a snapshot.
// Captures document metadata and file hash at the moment the offer was sent.
// If the underlying OfferDocument is later deleted, this record remains valid.
// No updatedAt — immutable after creation.

model OfferSnapshotDocument {
  id         String @id @default(cuid())
  snapshotId String
  documentId String
  // Fields frozen from OfferDocument at snapshot time
  filename   String
  storageKey String
  mimeType   String
  sizeBytes  Int
  sha256Hash String // copied from OfferDocument.sha256Hash — binds snapshot to exact file bytes

  snapshot OfferSnapshot @relation(fields: [snapshotId], references: [id])
  document OfferDocument @relation(fields: [documentId], references: [id])

  @@unique([snapshotId, documentId])
  @@index([snapshotId])
  @@map("offer_snapshot_documents")
}

// ─── OfferRecipient ───────────────────────────────────────────────────────────
// The single recipient for an offer in v1.
// offerId is @unique to enforce the one-recipient constraint at the database level.
// Remove @unique from offerId when multi-recipient is introduced.
//
// Token security model:
//   - Raw token format: oa_<base64url(32 random bytes)>  [256 bits of entropy]
//   - Raw token is generated once, embedded in the email link, NEVER stored.
//   - Only SHA-256(rawToken) is stored in tokenHash.
//   - Lookup: WHERE tokenHash = SHA256(incoming) AND tokenExpiresAt > NOW()
//             AND tokenInvalidatedAt IS NULL
//   - A used token is NOT automatically invalidated — the link can be re-opened
//     to re-enter an OTP if needed. Final acceptance requires OTP verification.

enum RecipientStatus {
  PENDING
  VIEWED
  OTP_VERIFIED
  ACCEPTED
  DECLINED
  EXPIRED
}

model OfferRecipient {
  id                 String          @id @default(cuid())
  // @unique enforces v1 single-recipient constraint — intentional, documented
  offerId            String          @unique
  email              String
  name               String
  // Hashed token — see security model above
  tokenHash          String          @unique
  tokenExpiresAt     DateTime
  tokenInvalidatedAt DateTime?
  status             RecipientStatus @default(PENDING)
  // Optimistic concurrency version — incremented on every status update.
  version            Int             @default(1)
  viewedAt           DateTime?
  respondedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  offer         Offer                @relation(fields: [offerId], references: [id])
  sessions      SigningSession[]
  otpChallenges SigningOtpChallenge[]

  @@index([tokenHash])
  @@map("offer_recipients")
}

// ─── SigningSession ───────────────────────────────────────────────────────────
// One session per visit to the signing link. A recipient may have multiple
// sessions (e.g., opened the link on two devices), but only one can reach ACCEPTED.
//
// A session is bound to a specific snapshot — it cannot be replayed against
// a different offer. snapshotId is set at creation and never changed.
//
// Status lifecycle:
//   AWAITING_OTP  → OTP_VERIFIED  → ACCEPTED
//                                 → DECLINED
//   AWAITING_OTP  → EXPIRED (TTL exceeded)
//   AWAITING_OTP  → ABANDONED (no activity)
//   OTP_VERIFIED  → EXPIRED
//   OTP_VERIFIED  → ABANDONED

enum SessionStatus {
  AWAITING_OTP  // token validated, OTP sent, waiting for verification
  OTP_VERIFIED  // email confirmed, recipient may submit acceptance
  ACCEPTED      // offer accepted
  DECLINED      // offer declined
  EXPIRED       // session TTL exceeded before completion
  ABANDONED     // no meaningful activity for a sustained period
}

model SigningSession {
  id            String        @id @default(cuid())
  recipientId   String
  // Denormalized for queries — always consistent with recipient.offerId
  offerId       String
  // Which snapshot was presented in this session — immutable after creation
  snapshotId    String
  // Network context at session creation
  ipAddress     String?
  userAgent     String?
  status        SessionStatus @default(AWAITING_OTP)
  // Optimistic concurrency version — incremented on every status update.
  // Used with updateMany WHERE version = ? to detect concurrent modifications.
  version       Int           @default(1)
  // Session TTL — set at creation, enforced by application + background job
  expiresAt     DateTime
  otpVerifiedAt DateTime?
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  updatedAt     DateTime      @updatedAt

  recipient        OfferRecipient        @relation(fields: [recipientId], references: [id])
  snapshot         OfferSnapshot         @relation(fields: [snapshotId], references: [id])
  events           SigningEvent[]
  otpChallenges    SigningOtpChallenge[]
  acceptanceRecord AcceptanceRecord?

  @@index([recipientId])
  @@index([offerId])
  @@index([snapshotId])
  @@map("signing_sessions")
}

// ─── SigningOtpChallenge ───────────────────────────────────────────────────────
// An OTP challenge issued to a recipient during a signing session.
// Only one challenge should be active per session at a time (invalidate old
// ones before creating new ones via invalidatedAt).
//
// OTP security model:
//   - Code: 6-digit numeric, generated with crypto.randomInt(100000, 999999)
//   - Storage: only SHA-256(code) is persisted — never the raw code
//   - TTL: short (10 minutes by default)
//   - Rate limiting: max 5 attempts before lockout (maxAttempts)
//   - Re-issue: a new challenge invalidates all prior ones for the same session
//
// channel is EMAIL for v1. The field is present to avoid a schema migration
// when SMS or other channels are added.

enum OtpChannel {
  EMAIL
}

// Explicit status makes state machine checks and queries unambiguous.
// Derived from (verifiedAt, invalidatedAt, attemptCount, expiresAt) but stored directly
// so the application layer never has to re-derive it from multiple nullable fields.
enum OtpChallengeStatus {
  PENDING      // active, awaiting code submission
  VERIFIED     // correct code submitted
  EXPIRED      // TTL exceeded before verification
  LOCKED       // maxAttempts reached without success
  INVALIDATED  // superseded by a new challenge for the same session
}

model SigningOtpChallenge {
  id              String             @id @default(cuid())
  sessionId       String
  recipientId     String
  channel         OtpChannel         @default(EMAIL)
  // For EMAIL: the address it was sent to (captured at issue time)
  deliveryAddress String
  // SHA-256 hex of the raw OTP code — raw code is never stored
  codeHash        String
  status          OtpChallengeStatus @default(PENDING)
  expiresAt       DateTime
  attemptCount    Int                @default(0)
  maxAttempts     Int                @default(5)
  // Set on successful verification; null if not yet verified
  verifiedAt      DateTime?
  // Set when this challenge is superseded by a new one or the session expires
  invalidatedAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  session   SigningSession  @relation(fields: [sessionId], references: [id])
  recipient OfferRecipient  @relation(fields: [recipientId], references: [id])

  @@index([sessionId])
  @@index([recipientId])
  @@map("signing_otp_challenges")
}

// ─── SigningEvent ─────────────────────────────────────────────────────────────
// Append-only audit log for all actions in the signing flow.
// NEVER update or delete rows in this table. No updatedAt.
//
// Hash chain model:
//   sequenceNumber: monotonically increasing per session, starting at 1
//   previousEventHash: eventHash of the prior event in this session (null for #1)
//   eventHash: SHA-256 of the canonical concatenation:
//     sessionId || "|" || sequenceNumber || "|" || eventType || "|"
//     || canonicalPayload || "|" || timestamp.toISOString() || "|"
//     || (previousEventHash ?? "GENESIS")
//   where canonicalPayload = JSON.stringify(payload, sortedKeys) or "" if null
//
// @@unique([sessionId, sequenceNumber]) prevents duplicate sequence numbers,
// which would allow forking the chain.
//
// To verify integrity: recompute eventHash for each event and confirm it
// matches the stored value, and that previousEventHash matches the prior event.

enum SigningEventType {
  // Session
  SESSION_STARTED       // token validated, session created
  SESSION_EXPIRED       // session TTL reached
  SESSION_ABANDONED     // inactivity timeout
  // Document interaction
  DOCUMENT_VIEWED       // recipient opened a specific document
  // OTP flow
  OTP_ISSUED            // OTP challenge created and sent
  OTP_ATTEMPT_FAILED    // incorrect code submitted
  OTP_MAX_ATTEMPTS      // max failed attempts reached; challenge locked
  OTP_VERIFIED          // correct code submitted; email verified
  // Acceptance
  OFFER_ACCEPTED        // final acceptance after OTP verification
  OFFER_DECLINED        // recipient declined the offer
}

model SigningEvent {
  id                String          @id @default(cuid())
  sessionId         String
  sequenceNumber    Int             // 1-based, unique per session
  eventType         SigningEventType
  // Event-specific structured data. Schema is validated in the application layer.
  // Examples:
  //   DOCUMENT_VIEWED:   { documentId, filename }
  //   OTP_ISSUED:        { channel, deliveryAddress, challengeId }
  //   OTP_ATTEMPT_FAILED:{ challengeId, attemptCount }
  //   OFFER_ACCEPTED:    { acceptanceStatement, verifiedEmail, locale, timezone }
  payload           Json?
  // Network context — captured per event (not just at session start)
  ipAddress         String?
  userAgent         String?
  // Hash chain — stored as lowercase hex-encoded SHA-256
  previousEventHash String?         // null for the first event in a session
  eventHash         String          // must be verified before trusting this event
  // Server-assigned. Client-supplied timestamps must not be used.
  timestamp         DateTime        @default(now())

  session SigningSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, sequenceNumber])
  @@index([sessionId])
  @@index([timestamp])
  @@map("signing_events")
}

// ─── AcceptanceRecord ─────────────────────────────────────────────────────────
// Structured, immutable record of everything known about the acceptance at the
// moment it was submitted. This is the primary input to certificate generation.
//
// It is created in the same transaction as the OFFER_ACCEPTED signing event.
// It is never updated after creation.
//
// snapshotContentHash is copied from OfferSnapshot.contentHash at creation time.
// This means the AcceptanceRecord is self-contained for certificate generation —
// the certificate can be regenerated from this record alone, without reading
// the current state of any mutable entity.

model AcceptanceRecord {
  id String @id @default(cuid())

  sessionId   String @unique
  recipientId String
  snapshotId  String

  // Exact text that was displayed to the recipient at the acceptance UI.
  // Stored verbatim so it can appear on the certificate.
  acceptanceStatement String   @db.Text

  // Evidence — all fields captured at the moment of acceptance
  verifiedEmail   String   // the email address that passed OTP verification
  emailVerifiedAt DateTime // when OTP was verified in this session
  acceptedAt      DateTime // when the recipient clicked Accept
  ipAddress       String?
  userAgent       String?
  locale          String?  // from Accept-Language header or Intl API
  timezone        String?  // from Intl.DateTimeFormat().resolvedOptions().timeZone

  // Snapshot binding — copied at creation for certificate independence.
  // Allows regenerating the certificate without reading OfferSnapshot.
  snapshotContentHash String

  // No updatedAt — immutable after creation
  createdAt DateTime @default(now())

  session     SigningSession         @relation(fields: [sessionId], references: [id])
  snapshot    OfferSnapshot         @relation(fields: [snapshotId], references: [id])
  certificate AcceptanceCertificate?

  @@index([recipientId])
  @@index([snapshotId])
  @@map("acceptance_records")
}

// ─── AcceptanceCertificate ────────────────────────────────────────────────────
// The tamper-evident artifact generated from an AcceptanceRecord.
// Generated asynchronously after AcceptanceRecord creation.
//
// certificateHash = SHA-256 of the canonical certificate content (the same
// input used to generate the PDF). Allows third-party verification without
// the PDF.
//
// Certificate content is derived from AcceptanceRecord + OfferSnapshot only.
// It does not re-read Offer, User, or Organization at generation time.

model AcceptanceCertificate {
  id                 String   @id @default(cuid())
  offerId            String   @unique  // for convenient dashboard lookups
  acceptanceRecordId String   @unique
  certificateHash    String   // SHA-256 hex of canonical certificate content
  pdfStorageKey      String?  // object storage key; null until PDF is generated
  issuedAt           DateTime @default(now())

  offer           Offer           @relation(fields: [offerId], references: [id])
  acceptanceRecord AcceptanceRecord @relation(fields: [acceptanceRecordId], references: [id])

  @@map("acceptance_certificates")
}

// ─── OfferDeliveryAttempt ──────────────────────────────────────────────────────
// Audit trail for every attempt to deliver the offer-link email to the recipient.
// Created immediately before the email provider call; outcome updated after.
//
// A new attempt is created for each send/resend action — history is preserved.
// The latest attempt record is authoritative for current delivery state.
//
// tokenHash is the SHA-256 of the rawToken embedded in the email for this attempt.
// Storing it here allows matching which signing link was sent in each email,
// even after the token is replaced by a subsequent resend.
//
// attemptedBy: null means the system triggered it (initial send flow).
//              A userId means an authenticated sender requested a resend.
//
// Outcome states:
//   DISPATCHING          — email call in progress; never left in this state
//   DELIVERED_TO_PROVIDER — provider returned 2xx; email accepted for delivery
//   FAILED               — provider returned non-2xx or network error occurred

enum DeliveryOutcome {
  DISPATCHING
  DELIVERED_TO_PROVIDER
  FAILED
}

model OfferDeliveryAttempt {
  id             String          @id @default(cuid())
  offerId        String
  recipientEmail String
  // SHA-256 of the rawToken that was embedded in the signing URL for this attempt.
  // Immutable after creation — records which link was sent.
  tokenHash      String
  outcome        DeliveryOutcome
  // HTTP status code returned by the email provider (null if DISPATCHING or network error)
  failureCode    Int?
  // Human-readable error from the provider or runtime (null on success)
  failureReason  String?
  // null = system-initiated (initial send); userId = sender-requested resend
  attemptedBy    String?
  attemptedAt    DateTime        @default(now())

  offer Offer @relation(fields: [offerId], references: [id])

  @@index([offerId])
  @@index([attemptedAt])
  @@map("offer_delivery_attempts")
}

// ─── SupportAuditLog ──────────────────────────────────────────────────────────
// Append-only audit trail for all INTERNAL_SUPPORT reads and actions.
//
// Rules:
//   - Never update or delete rows. append-only.
//   - metadata must never contain secrets, tokens, OTP codes, or raw passwords.
//   - actorId is the sub claim from the support user's JWT — always from the
//     server-verified token, never from request body.
//
// resourceType + resourceId identify the entity acted upon:
//   offer:{offerId}, session:{sessionId}, certificate:{certId}
//
// This table is the authoritative audit source for compliance reviews and
// dispute investigations involving internal staff access.

model SupportAuditLog {
  id             String   @id @default(cuid())
  // Support user who performed the action (JWT sub — never request-supplied)
  actorId        String
  // Action enum: SEARCH_OFFERS, READ_CASE, READ_TIMELINE, READ_SESSION_EVENTS,
  //              REVOKE_OFFER, RESEND_OFFER_LINK, RESEND_SESSION_OTP
  action         String
  resourceType   String   // 'offer' | 'session' | 'certificate'
  resourceId     String
  // Owning org of the resource — null when resource is cross-org (search results)
  organizationId String?
  timestamp      DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  // Safe structured detail — see rules above: NO secrets, tokens, or OTPs
  metadata       Json?

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([timestamp])
  @@map("support_audit_logs")
}

// ─── ReminderSchedule ─────────────────────────────────────────────────────────
// Tracks the automated reminder cadence for a single SENT offer.
// One row per offer, created when the offer is sent and deleted when it reaches
// a terminal state (ACCEPTED, DECLINED, EXPIRED, REVOKED).
//
// Reminder cadence (from dealSentAt):
//   Reminder 1: +24 h
//   Reminder 2: +72 h
//   Reminder 3: +120 h (5 days)
//
// nextReminderAt is null when all 3 reminders have been sent.
// The row is kept alive after all reminders are sent so that expiry warnings
// (warning24hSentAt, warning2hSentAt) can still be tracked and fired.
//
// The send-reminders background job sweeps this table every 5 minutes.

model ReminderSchedule {
  id             String    @id @default(cuid())
  offerId        String    @unique
  // Timestamp the deal was sent — anchor for all reminder timing calculations.
  dealSentAt     DateTime
  // Next scheduled reminder to the recipient; null when all 3 have been sent.
  nextReminderAt DateTime?
  // Count of reminders sent so far: 0 = none, 1 = R1 sent, 2 = R2 sent, 3 = R3 sent.
  reminderCount  Int       @default(0)
  // Expiry warnings to the deal sender. Null = not yet sent.
  warning24hSentAt DateTime?
  warning2hSentAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  offer Offer @relation(fields: [offerId], references: [id])

  // Used by the reminder sweep: WHERE nextReminderAt <= NOW()
  @@index([nextReminderAt])
  @@map("reminder_schedules")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  // Set by Stripe when the customer cancels but keeps access until end of period.
  // On next subscription.deleted webhook, status becomes CANCELED.
  cancelAtPeriodEnd    Boolean            @default(false)
  // Running count of offers sent this calendar month. Reset by cron on the 1st.
  monthlyOfferCount    Int                @default(0)
  // Timestamp of the last monthly usage reset. Used by the reset job as an
  // idempotency guard — prevents double-reset if the cron fires more than once
  // in the same calendar month (e.g. after a restart on the 1st).
  lastUsageReset       DateTime?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

// ─── ApiKey ───────────────────────────────────────────────────────────────────
// Programmatic access credential for enterprise integrations.
//
// Key format: oa_<base64url(32 random bytes)>  — 256 bits of entropy
// Security model (identical to token/OTP pattern used throughout):
//   - Raw key is generated once, returned to the user ONCE, never stored.
//   - Only SHA-256(rawKey) is stored in keyHash.
//   - Lookup: WHERE keyHash = SHA256(incoming) AND revokedAt IS NULL
//             AND (expiresAt IS NULL OR expiresAt > NOW())
//
// keyPrefix: first 12 characters of the raw key (e.g. "oa_abc123xyz0").
// Never enough to reconstruct the full key; used for display/revocation UIs only.
//
// lastUsedAt: updated on each successful authentication — visibility for key rotation.
// revokedAt: set on explicit revocation — row kept for audit; not physically deleted.

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String    @db.VarChar(100)  // e.g. "CRM Integration", "Zapier"
  // SHA-256 hex of the full raw key — raw key is NEVER stored
  keyHash        String    @unique
  // First 12 characters of the raw key for identification in the UI.
  // Cannot be used to reconstruct or brute-force the full key.
  keyPrefix      String    @db.VarChar(16)
  lastUsedAt     DateTime?
  expiresAt      DateTime?            // null = never expires
  revokedAt      DateTime?            // null = active; set on revocation
  createdAt      DateTime  @default(now())
  createdById    String               // userId of the creator

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("api_keys")
}

// ─── WebhookEndpoint ──────────────────────────────────────────────────────────
// A customer-configured HTTPS endpoint that receives outgoing webhook events.
//
// secret: server-generated HMAC-SHA256 signing key (32 random bytes, hex-encoded).
//   Returned ONCE at creation. Customers use it to verify the X-OfferAccept-Signature
//   header on incoming payloads. Rotate via DELETE + POST if compromised.
//
// events: set of event types this endpoint is subscribed to.
//   Valid values are a subset of ALL_WEBHOOK_EVENTS in webhook.service.ts.
//
// enabled: soft-disable without deleting history. Disabled endpoints receive no
//   deliveries; jobs for them are dropped without retry.

model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  url            String   @db.Text           // customer's HTTPS endpoint
  // HMAC-SHA256 signing key — returned once at creation, never returned again.
  // Stored server-side to sign outgoing payloads. Not a user credential.
  secret         String   @db.VarChar(64)    // 32 bytes hex-encoded
  // Subscribed event types. Application layer validates against allowed set.
  events         String[]
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization             @relation(fields: [organizationId], references: [id])
  deliveryAttempts WebhookDeliveryAttempt[]

  @@index([organizationId])
  @@map("webhook_endpoints")
}

// ─── WebhookDeliveryAttempt ───────────────────────────────────────────────────
// Append-only audit log of every HTTP delivery attempt to a webhook endpoint.
// One row per attempt (retries of the same logical event create separate rows).
//
// Replay protection:
//   webhookEventId is a UUID stable across all retries of the same logical event
//   (e.g. the same offer.accepted event for the same endpoint). Before making an
//   HTTP call, the handler checks for an existing row with success=true. If found,
//   it skips delivery — preventing re-delivery of already-confirmed events even if
//   pg-boss re-runs the job (e.g. after a process crash post-delivery).
//
// attempt: 1-based retry counter — first delivery is attempt=1.
// httpStatus: null if the connection failed before receiving a response.
// responseBody: truncated to 1000 bytes; for debugging only.

model WebhookDeliveryAttempt {
  id             String   @id @default(cuid())
  endpointId     String
  // Stable across retries — identifies the logical event dispatch.
  // Customers may use this as their own idempotency key.
  webhookEventId String
  event          String              // e.g. "offer.accepted"
  httpStatus     Int?                // null on connection error
  responseBody   String?  @db.Text  // truncated to 1000 bytes
  attempt        Int                 // 1-based retry counter
  success        Boolean             // true if HTTP 2xx received
  deliveredAt    DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId])
  @@index([endpointId, webhookEventId])
  @@map("webhook_delivery_attempts")
}
