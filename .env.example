# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/offeraccept_dev"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_BASE_URL="http://localhost:3001"
WEB_BASE_URL="http://localhost:3000"

# ─── Auth / Session ──────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRY="7d"

# ─── Signing Links ───────────────────────────────────────────────────────────
# Secret used to sign recipient tokens in email links
SIGNING_LINK_SECRET="change-me-in-production-min-32-chars"

# ─── Email (Resend or SMTP) ───────────────────────────────────────────────────
EMAIL_PROVIDER="resend"  # "resend" | "smtp"
RESEND_API_KEY=""
EMAIL_FROM="noreply@offeraccept.com"

# ─── Storage (S3-compatible) ──────────────────────────────────────────────────
STORAGE_PROVIDER="s3"
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Legal ────────────────────────────────────────────────────────────────────
# Enable strict legal compliance mode (required for EEA production deployments).
# When true: acceptance statement must be non-empty; GDPR Article 14 notice is
# unconditionally rendered before OTP (enforced client-side — always on).
LEGAL_MODE_STRICT=false

# ─── Data Retention ───────────────────────────────────────────────────────────
# How long signing links remain valid (days). Short window limits compromise risk.
TOKEN_EXPIRY_DAYS=30
# Retention period for acceptance evidence (years).
# Records are preserved for legal claim support under GDPR Art. 17(3)(e).
# Immutable tables (AcceptanceRecord, OfferSnapshot, SigningEvent) are never
# deleted — this setting controls archival of mutable signing session data.
ACCEPTANCE_RETENTION_YEARS=10
# Retention period for active deal event rows before archival to cold storage.
DEAL_EVENT_RETENTION_MONTHS=18
