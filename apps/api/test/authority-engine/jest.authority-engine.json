{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "testEnvironment": "node",
  "testMatch": ["**/test/authority-engine/gates/**/*.spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.json"
    }]
  },
  "moduleNameMapper": {
    "^pg-boss$": "<rootDir>/test/__mocks__/pg-boss.ts",
    "^@offeraccept/database$": "<rootDir>/../../packages/database/src/index.ts",
    "^@offeraccept/types$": "<rootDir>/../../packages/types/src/index.ts"
  },
  "reporters": [
    "default",
    "<rootDir>/test/authority-engine/reporter.js"
  ],
  "testPathIgnorePatterns": ["/node_modules/", "/dist/"],
  "testTimeout": 30000,
  "verbose": true,
  "forceExit": true
}
