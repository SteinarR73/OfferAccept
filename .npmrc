# Fail fast if Node version does not meet the engines.node requirement
# declared in package.json. Prevents subtle runtime differences when a
# developer or CI runner uses an older Node.
engine-strict=true

# Prevent accidental npm/yarn installs in a pnpm workspace.
# The preinstall script in package.json runs `npx only-allow pnpm` which
# gives a clear error message; this setting provides a second line of defence.
# See: https://pnpm.io/npmrc#manage-package-manager-with-corepack
