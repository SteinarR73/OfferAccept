# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files
.env
.env.local
.env.*.local

# Turbo
.turbo/

# Prisma
# Keep migrations in source control, but not the generated client
packages/database/node_modules/

# SQLite — never commit database files; these are dev/test artefacts only.
# If dev.db is already tracked, run: git rm --cached prisma/dev.db
prisma/*.db
prisma/*.db-wal
prisma/*.db-shm
*.db
*.db-wal
*.db-shm

# Security audit outputs — contain redacted credential info, never commit
docs/security/audit-report.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/

# Type declarations (generated)
*.d.ts.map

# TypeScript incremental build cache — never commit build artefacts
*.tsbuildinfo

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
